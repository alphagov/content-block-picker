{
  "name": "content-block-editor",
  "version": "0.6.2",
  "type": "module",
  "main": "./dist/content-block-editor.umd.cjs",
  "module": "./dist/content-block-editor.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && npm run build-examples",
    "build-examples": "rm -rf examples/dist && cp -r dist examples/dist",
    "preview": "vite preview",
    "test": "vitest",
    "e2e-test": "playwright test",
    "e2e-test-ui": "playwright test --ui",
    "lint": "eslint .",
    "prettier:check": "prettier . --check",
    "prettier:write": "prettier . --write"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@golevelup/ts-vitest": "^4.0.0",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "sass-embedded": "^1.100.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "govuk-frontend": "^6.1.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "vitest": "^4.1.7"
  }
}
